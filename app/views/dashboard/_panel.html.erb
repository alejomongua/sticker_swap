<%= turbo_frame_tag "dashboard_panel" do %>
  <div class="space-y-8">
    <%= render "shared/flash" if turbo_frame_request? && !request.format.turbo_stream? %>

    <%= render "dashboard/inventory_summary" %>

    <section class="space-y-4">
      <div class="space-y-2">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Movimientos rápidos</h2>
        <p class="text-sm text-slate-600">Registra lo que abriste, lo que te falta y lo que ya cambiaste sin salir del panel.</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-slate-950">Agregar faltantes</h2>
          <p class="text-sm text-slate-600">Pega códigos separados por coma, espacio o salto de línea. Ejemplo: <span class="font-medium text-slate-800">ARG1, ARG2, FWC3</span></p>
        </div>

        <div class="mt-4">
          <%= link_to "Abrir tabla interactiva",
                      missing_table_dashboard_path,
                      data: { turbo: false },
                      class: "inline-flex items-center justify-center rounded-2xl border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-900 transition hover:border-amber-400 hover:bg-amber-100" %>
        </div>

        <%= form_with model: InventoryItem.new, url: inventory_items_path, class: "mt-5 space-y-4", data: { turbo_frame: "dashboard_panel", turbo_stream: true } do |form| %>
          <%= form.hidden_field :status, value: :missing %>
          <%= hidden_field_tag :duplicate_mode, @duplicate_mode %>
          <%= hidden_field_tag :duplicate_prefix, @duplicate_prefix %>
          <%= hidden_field_tag :duplicate_code, @duplicate_code %>
          <%= hidden_field_tag :duplicates_page, @duplicate_page %>
          <%= hidden_field_tag :missing_prefix, @missing_prefix %>
          <%= hidden_field_tag :missing_code, @missing_code %>
          <%= hidden_field_tag :missing_page, @missing_page %>
          <div class="space-y-2">
            <%= form.label :codes, "Figuras faltantes", for: "missing_inventory_codes", class: "block text-sm font-medium text-slate-700" %>
            <%= form.text_area :codes, id: "missing_inventory_codes", rows: 6, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
          </div>

          <%= form.submit "Guardar faltantes", class: "inline-flex items-center justify-center rounded-2xl bg-amber-500 px-5 py-3 font-medium text-white transition hover:bg-amber-600" %>
        <% end %>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-slate-950">Agregar repetidas</h2>
          <p class="text-sm text-slate-600">Usa el modo individual para ajustar cantidad o el modo masivo para pegar varias fichas y sumar una copia por cada aparición.</p>
        </div>

        <%= form_with model: InventoryItem.new,
                url: inventory_items_path,
                class: "mt-5 space-y-4",
                data: { controller: "duplicate-form", turbo_frame: "dashboard_panel", turbo_stream: true } do |form| %>
          <%= form.hidden_field :status, value: :duplicate %>
          <%= hidden_field_tag :duplicate_prefix, @duplicate_prefix %>
          <%= hidden_field_tag :duplicate_code, @duplicate_code %>
          <%= hidden_field_tag :duplicates_page, @duplicate_page %>
          <%= hidden_field_tag :missing_prefix, @missing_prefix %>
          <%= hidden_field_tag :missing_code, @missing_code %>
          <%= hidden_field_tag :missing_page, @missing_page %>

          <div class="space-y-2">
            <%= label_tag :duplicate_mode, "Modo de carga", class: "block text-sm font-medium text-slate-700" %>
            <%= select_tag :duplicate_mode,
                           options_for_select([["Individual", "single"], ["Masivo", "bulk"]], @duplicate_mode),
                           class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 focus:border-accent-700 focus:ring-accent-700",
                           data: { action: "change->duplicate-form#sync", duplicate_form_target: "mode" } %>
          </div>

          <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_10rem_auto] sm:items-end <%= "hidden" if @duplicate_mode == "bulk" %>" data-duplicate-form-target="singlePanel">
            <div class="space-y-2">
              <%= label_tag "duplicate_inventory_code", "Código de la figura", class: "block text-sm font-medium text-slate-700" %>
              <%= text_field_tag "inventory_item[code]", nil,
                                 id: "duplicate_inventory_code",
                                 placeholder: "ARG1",
                                 autocomplete: "off",
                                 disabled: @duplicate_mode == "bulk",
                                 class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm uppercase text-slate-950 focus:border-accent-700 focus:ring-accent-700",
                                 data: { duplicate_form_target: "singleCode" } %>
            </div>

            <div class="space-y-2">
              <%= label_tag "duplicate_inventory_quantity", "Repeticiones", class: "block text-sm font-medium text-slate-700" %>
              <%= number_field_tag "inventory_item[quantity]", 1,
                                   id: "duplicate_inventory_quantity",
                                   min: 1,
                                   step: 1,
                                   disabled: @duplicate_mode == "bulk",
                                   class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 focus:border-accent-700 focus:ring-accent-700",
                                   data: { duplicate_form_target: "singleQuantity" } %>
            </div>

            <%= form.submit "Agregar repetida", class: "inline-flex items-center justify-center rounded-2xl bg-emerald-600 px-5 py-3 font-medium text-white transition hover:bg-emerald-700" %>
          </div>

          <div class="space-y-4 <%= "hidden" unless @duplicate_mode == "bulk" %>" data-duplicate-form-target="bulkPanel">
            <div class="space-y-2">
              <%= form.label :codes, "Fichas repetidas", for: "duplicate_inventory_codes", class: "block text-sm font-medium text-slate-700" %>
              <%= form.text_area :codes,
                                 id: "duplicate_inventory_codes",
                                 rows: 6,
                                 disabled: @duplicate_mode != "bulk",
                                 class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm uppercase text-slate-950 focus:border-accent-700 focus:ring-accent-700",
                                 data: { duplicate_form_target: "bulkCodes" } %>
              <p class="text-xs text-slate-500">Acepta comas, espacios o saltos de línea. Si una ficha aparece dos veces, suma dos copias.</p>
            </div>

            <%= hidden_field_tag "inventory_item[quantity]", 1, disabled: @duplicate_mode != "bulk", data: { duplicate_form_target: "bulkQuantity" } %>
            <%= form.submit "Agregar repetidas", class: "inline-flex items-center justify-center rounded-2xl bg-emerald-600 px-5 py-3 font-medium text-white transition hover:bg-emerald-700" %>
          </div>
        <% end %>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50 lg:col-span-2 xl:col-span-1">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-slate-950">Agregar nuevas figuras</h2>
          <p class="text-sm text-slate-600">Pega las figuras que abriste en un sobre. Si estaban en faltantes se eliminan; si no, se suman como repetidas.</p>
        </div>

        <%= form_with model: InventoryItem.new, url: add_new_inventory_items_path, class: "mt-5 space-y-4", data: { turbo_frame: "dashboard_panel", turbo_stream: true } do |form| %>
          <%= hidden_field_tag :duplicate_mode, @duplicate_mode %>
          <%= hidden_field_tag :duplicate_prefix, @duplicate_prefix %>
          <%= hidden_field_tag :duplicate_code, @duplicate_code %>
          <%= hidden_field_tag :duplicates_page, @duplicate_page %>
          <%= hidden_field_tag :missing_prefix, @missing_prefix %>
          <%= hidden_field_tag :missing_code, @missing_code %>
          <%= hidden_field_tag :missing_page, @missing_page %>
          <div class="space-y-2">
            <%= form.label :codes, "Figuras nuevas", for: "new_inventory_codes", class: "block text-sm font-medium text-slate-700" %>
            <%= form.text_area :codes,
                               id: "new_inventory_codes",
                               rows: 6,
                               class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm uppercase text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
            <p class="text-xs text-slate-500">Si una ficha aparece dos veces y estaba en faltantes, una copia la resuelve y el resto queda como repetida.</p>
          </div>

          <%= form.submit "Registrar nuevas figuras", class: "inline-flex items-center justify-center rounded-2xl bg-indigo-600 px-5 py-3 font-medium text-white transition hover:bg-indigo-700" %>
        <% end %>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-slate-950">Registrar conseguidas</h2>
          <p class="text-sm text-slate-600">Pega varias fichas que ya conseguiste para quitarlas de tus faltantes de una sola vez.</p>
        </div>

        <%= form_with model: InventoryItem.new, url: consume_inventory_items_path, class: "mt-5 space-y-4", data: { turbo_frame: "dashboard_panel", turbo_stream: true } do |form| %>
          <%= form.hidden_field :status, value: :missing %>
          <%= hidden_field_tag :duplicate_mode, @duplicate_mode %>
          <%= hidden_field_tag :duplicate_prefix, @duplicate_prefix %>
          <%= hidden_field_tag :duplicate_code, @duplicate_code %>
          <%= hidden_field_tag :duplicates_page, @duplicate_page %>
          <%= hidden_field_tag :missing_prefix, @missing_prefix %>
          <%= hidden_field_tag :missing_code, @missing_code %>
          <%= hidden_field_tag :missing_page, @missing_page %>
          <div class="space-y-2">
            <%= form.label :codes, "Fichas conseguidas", for: "resolved_inventory_codes", class: "block text-sm font-medium text-slate-700" %>
            <%= form.text_area :codes,
                               id: "resolved_inventory_codes",
                               rows: 6,
                               class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm uppercase text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
            <p class="text-xs text-slate-500">Acepta comas, espacios o saltos de línea. Cada código se elimina de tus faltantes si estaba cargado.</p>
          </div>

          <%= form.submit "Quitar de faltantes", class: "inline-flex items-center justify-center rounded-2xl bg-sky-600 px-5 py-3 font-medium text-white transition hover:bg-sky-700" %>
        <% end %>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-slate-950">Registrar repetidas cambiadas</h2>
          <p class="text-sm text-slate-600">Pega las fichas repetidas que entregaste o cambiaste para descontar una copia por cada aparición.</p>
        </div>

        <%= form_with model: InventoryItem.new, url: consume_inventory_items_path, class: "mt-5 space-y-4", data: { turbo_frame: "dashboard_panel", turbo_stream: true } do |form| %>
          <%= form.hidden_field :status, value: :duplicate %>
          <%= hidden_field_tag :duplicate_mode, @duplicate_mode %>
          <%= hidden_field_tag :duplicate_prefix, @duplicate_prefix %>
          <%= hidden_field_tag :duplicate_code, @duplicate_code %>
          <%= hidden_field_tag :duplicates_page, @duplicate_page %>
          <%= hidden_field_tag :missing_prefix, @missing_prefix %>
          <%= hidden_field_tag :missing_code, @missing_code %>
          <%= hidden_field_tag :missing_page, @missing_page %>
          <div class="space-y-2">
            <%= form.label :codes, "Repetidas cambiadas", for: "consumed_duplicate_codes", class: "block text-sm font-medium text-slate-700" %>
            <%= form.text_area :codes,
                               id: "consumed_duplicate_codes",
                               rows: 6,
                               class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm uppercase text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
            <p class="text-xs text-slate-500">Acepta comas, espacios o saltos de línea. Si una ficha aparece dos veces, descuenta dos copias y la elimina al llegar a cero.</p>
          </div>

          <%= form.submit "Descontar repetidas", class: "inline-flex items-center justify-center rounded-2xl bg-rose-600 px-5 py-3 font-medium text-white transition hover:bg-rose-700" %>
        <% end %>
      </div>
    </div>

    </section>

    <section class="space-y-4">
      <div class="space-y-2">
        <h2 class="text-2xl font-semibold tracking-tight text-slate-950">Inventario actual</h2>
        <p class="text-sm text-slate-600">Filtra tus faltantes y repetidas. Si necesitas sincronizar o copiar listas en texto, usa la vista de importar y exportar.</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
      <%= render "dashboard/missing_inventory" %>

      <%= render "dashboard/duplicate_inventory" %>
      </div>
    </section>
  </div>
<% end %>