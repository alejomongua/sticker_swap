<div class="grid gap-6 lg:grid-cols-[minmax(0,1.5fr)_minmax(18rem,1fr)]">
  <div class="flex flex-col gap-4 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50 sm:flex-row sm:items-end sm:justify-between">
    <div class="space-y-2">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-950">Tu inventario</h1>
      <p class="text-sm text-slate-600">Carga faltantes y repetidas desde el mismo panel.</p>
    </div>

    <div class="flex flex-wrap gap-3 text-sm font-medium">
      <div class="rounded-full bg-amber-100 px-4 py-2 text-amber-900">Faltantes: <%= @missing_items.size %></div>
      <div class="rounded-full bg-emerald-100 px-4 py-2 text-emerald-900">Repetidas: <%= @duplicate_copies_count %></div>
      <%= link_to "Ver progreso", progress_path, class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950" %>
      <% if statistics_available? %>
        <%= link_to "Ver estadísticas", statistics_path, class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950" %>
      <% end %>
    </div>
  </div>

  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h2 class="text-lg font-semibold text-slate-950">Avance estimado</h2>
        <p class="text-sm text-slate-600">Se calcula con base en tus faltantes cargadas.</p>
      </div>

      <% if @progress_summary.tracked? %>
        <span class="text-2xl font-semibold tracking-tight text-slate-950"><%= number_to_percentage(@progress_summary.completion_percentage, precision: 1) %></span>
      <% else %>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium uppercase tracking-wide text-slate-600">Sin datos</span>
      <% end %>
    </div>

    <% if @progress_summary.tracked? %>
      <div class="mt-5 h-3 overflow-hidden rounded-full bg-slate-200">
        <div class="h-full rounded-full bg-amber-500 transition-all" style="width: <%= @progress_summary.completion_percentage %>%"></div>
      </div>
      <p class="mt-3 text-sm text-slate-600"><%= @progress_summary.owned_stickers_count %> de <%= @progress_summary.catalog_stickers_count %> fichas estimadas.</p>
    <% else %>
      <p class="mt-5 text-sm text-slate-600">Agrega al menos una ficha faltante para calcular tu porcentaje.</p>
    <% end %>
  </div>
</div>