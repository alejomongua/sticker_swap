<%= turbo_frame_tag "missing_table" do %>
  <div class="space-y-6">
    <%= render "shared/flash" if turbo_frame_request? && !request.format.turbo_stream? %>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div class="space-y-1">
          <h1 class="text-2xl font-semibold tracking-tight text-slate-950">Tabla interactiva de faltantes</h1>
          <p class="text-sm text-slate-600">Haz clic sobre cada ficha para alternar su estado. En rojo quedan las faltantes y en verde las conseguidas.</p>
        </div>

        <div class="flex flex-wrap items-center gap-3">
          <span class="rounded-full bg-amber-100 px-4 py-2 text-sm font-medium text-amber-900"><%= @missing_total_count %> faltantes</span>
          <%= link_to "Volver al panel", dashboard_path, class: "inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950" %>
        </div>
      </div>
    </div>

    <div class="max-h-[70vh] space-y-4 overflow-y-auto pr-1">
      <% @stickers_by_prefix.each do |prefix, stickers| %>
        <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm shadow-slate-200/40">
          <div class="mb-3 flex items-center justify-between gap-3">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700"><%= prefix.presence || "Sin prefijo" %></h2>
            <span class="text-xs text-slate-500"><%= stickers.size %> fichas</span>
          </div>

          <table class="w-full table-fixed border-separate border-spacing-1">
            <tbody>
              <% stickers.each_slice(6) do |row_stickers| %>
                <tr>
                  <% row_stickers.each do |sticker| %>
                    <% missing_item = @missing_items_by_sticker_id[sticker.id] %>
                    <% missing = missing_item.present? %>
                    <% button_classes = missing ? "bg-rose-100 text-rose-900 hover:bg-rose-200" : "bg-emerald-100 text-emerald-900 hover:bg-emerald-200" %>
                    <td class="align-top">
                      <% if missing %>
                        <%= button_to inventory_item_path(missing_item),
                                      method: :delete,
                                      form: { data: { turbo_frame: "missing_table" } },
                                      class: "w-full rounded-xl px-2 py-2 text-left text-xs font-semibold transition #{button_classes}",
                                      title: sticker.name.to_s do %>
                          <span class="block"><%= sticker.code %></span>
                        <% end %>
                      <% else %>
                        <%= button_to inventory_items_path,
                                      method: :post,
                                      form: { data: { turbo_frame: "missing_table" } },
                                      class: "w-full rounded-xl px-2 py-2 text-left text-xs font-semibold transition #{button_classes}",
                                      params: {
                                        inventory_item: {
                                          status: "missing",
                                          codes: sticker.code
                                        }
                                      },
                                      title: sticker.name.to_s do %>
                          <span class="block"><%= sticker.code %></span>
                        <% end %>
                      <% end %>
                    </td>
                  <% end %>

                  <% (6 - row_stickers.length).times do %>
                    <td></td>
                  <% end %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </section>
      <% end %>
    </div>
  </div>
<% end %>