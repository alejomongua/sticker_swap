<% content_for :title, "Importar y exportar" %>

<section class="space-y-8">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div class="space-y-2">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-950">Importar y exportar</h1>
      <p class="text-sm text-slate-600">Sincroniza tu inventario desde un formato externo o copia tus listas actuales en texto sin recargar el panel principal.</p>
    </div>

    <div class="flex flex-wrap gap-3">
      <%= link_to "Volver al panel", dashboard_path, class: "inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950" %>
      <%= link_to "Abrir tabla de faltantes", missing_table_dashboard_path, data: { turbo: false }, class: "inline-flex items-center justify-center rounded-2xl border border-amber-300 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-900 transition hover:border-amber-400 hover:bg-amber-100" %>
    </div>
  </div>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,1.15fr)_minmax(0,1.15fr)_minmax(18rem,1fr)]">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
      <div class="space-y-2">
        <h2 class="text-xl font-semibold text-slate-950">Importar desde Figuritas App</h2>
        <p class="text-sm text-slate-600">Pega el texto exportado completo. Esta importación reemplaza tus faltantes y repetidas actuales.</p>
      </div>

      <%= form_with scope: :inventory_import, url: import_inventory_items_path, class: "mt-5 space-y-4" do |form| %>
        <div class="space-y-2">
          <%= form.label :text, "Texto exportado", class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_area :text, rows: 16, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
          <p class="text-xs text-slate-500">Busca las secciones "Me faltan" y "Repetidas". Si una repetida aparece dos veces en el texto, se guardan dos copias.</p>
        </div>

        <%= form.submit "Importar inventario", class: "inline-flex items-center justify-center rounded-2xl bg-accent-700 px-5 py-3 font-medium text-white transition hover:bg-accent-900" %>
      <% end %>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
      <div class="space-y-2">
        <h2 class="text-xl font-semibold text-slate-950">Comparar una lista externa</h2>
        <p class="text-sm text-slate-600">Pega una exportación de figuritas.app para ver qué le puedes ofrecer y qué podrías recibir, sin importar si la otra persona usa StickerSwap.</p>
      </div>

      <%= form_with scope: :external_inventory_match, url: compare_import_export_dashboard_path, class: "mt-5 space-y-4", data: { turbo: false } do |form| %>
        <div class="space-y-2">
          <%= form.label :text, "Lista externa", class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_area :text, value: @external_inventory_text, rows: 16, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
          <p class="text-xs text-slate-500">Solo analiza el cruce. No modifica tu inventario ni crea una cuenta para la otra persona.</p>
        </div>

        <%= form.submit "Analizar cruce", class: "inline-flex items-center justify-center rounded-2xl bg-sky-600 px-5 py-3 font-medium text-white transition hover:bg-sky-700" %>
      <% end %>

      <% if @external_inventory_match.present? %>
        <div class="mt-6 space-y-4 border-t border-slate-200 pt-6">
          <% if @external_inventory_match.error_message.present? %>
            <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-4 text-sm text-rose-900">
              <p class="font-medium">No pudimos analizar esa lista</p>
              <p class="mt-1"><%= @external_inventory_match.error_message %></p>
            </div>
          <% else %>
            <% if @external_inventory_match.unknown_codes.any? %>
              <div class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm text-amber-900">
                No se encontraron estas fichas en el catálogo: <%= @external_inventory_match.unknown_codes.join(', ') %>.
              </div>
            <% end %>

            <div class="flex flex-wrap gap-3 text-sm font-medium">
              <% if @external_inventory_match.direct_match? %>
                <span class="rounded-full bg-emerald-100 px-4 py-2 text-emerald-900">Cruce directo</span>
              <% elsif @external_inventory_match.any_match? %>
                <span class="rounded-full bg-sky-100 px-4 py-2 text-sky-900">Coincidencia parcial</span>
              <% else %>
                <span class="rounded-full bg-slate-100 px-4 py-2 text-slate-700">Sin cruce</span>
              <% end %>
            </div>

            <div class="grid gap-6 lg:grid-cols-2">
              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Te puede dar</h3>
                <% if @external_inventory_match.can_request.any? %>
                  <ul class="mt-3 flex flex-wrap gap-2">
                    <% @external_inventory_match.can_request.each do |sticker| %>
                      <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"><%= sticker.display_name %></li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="mt-3 text-sm text-slate-600">No aparecen repetidas que hoy te falten.</p>
                <% end %>
              </div>

              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Le puedes ofrecer</h3>
                <% if @external_inventory_match.can_offer.any? %>
                  <ul class="mt-3 flex flex-wrap gap-2">
                    <% @external_inventory_match.can_offer.each do |sticker| %>
                      <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"><%= sticker.display_name %></li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="mt-3 text-sm text-slate-600">No necesita ninguna de tus repetidas actuales.</p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
      <div class="space-y-2">
        <h2 class="text-xl font-semibold text-slate-950">Resumen actual</h2>
        <p class="text-sm text-slate-600">Usa esta vista para sincronizar tu inventario completo. La importación reemplaza tus faltantes y repetidas actuales.</p>
      </div>

      <div class="mt-5 flex flex-wrap gap-3 text-sm font-medium">
        <span class="rounded-full bg-amber-100 px-4 py-2 text-amber-900"><%= @missing_total_count %> faltantes</span>
        <span class="rounded-full bg-emerald-100 px-4 py-2 text-emerald-900"><%= @duplicate_copies_count %> repetidas</span>
        <span class="rounded-full bg-slate-100 px-4 py-2 text-slate-700"><%= @duplicate_items_count %> fichas repetidas</span>
      </div>

      <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-600">
        <p class="font-medium text-slate-800">Qué reconoce el importador</p>
        <p class="mt-2">Lee las secciones "Me faltan" y "Repetidas" del formato de Figuritas App. Los códigos desconocidos se ignoran y se reportan en una alerta o en el análisis inline.</p>
      </div>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50" data-controller="clipboard">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-slate-950">Exportar faltantes</h2>
          <p class="text-sm text-slate-600">Copia tus faltantes como texto plano, en orden de catálogo.</p>
        </div>

        <%= button_tag type: "button",
                       disabled: @missing_codes_text.blank?,
                       class: "inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 disabled:cursor-not-allowed disabled:opacity-50",
                       data: { action: "click->clipboard#copy", clipboard_success_label_value: "Copiado" } do %>
          <span data-clipboard-target="label">Copiar faltantes</span>
        <% end %>
      </div>

      <%= text_area_tag :missing_export_text,
                        @missing_codes_text,
                        rows: 10,
                        readonly: true,
                        data: { clipboard_target: "source" },
                        class: "mt-5 block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50" data-controller="clipboard">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-slate-950">Exportar repetidas</h2>
          <p class="text-sm text-slate-600">Copia tus repetidas como texto plano, repitiendo cada copia disponible.</p>
        </div>

        <%= button_tag type: "button",
                       disabled: @duplicate_codes_text.blank?,
                       class: "inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50 hover:text-slate-950 disabled:cursor-not-allowed disabled:opacity-50",
                       data: { action: "click->clipboard#copy", clipboard_success_label_value: "Copiado" } do %>
          <span data-clipboard-target="label">Copiar repetidas</span>
        <% end %>
      </div>

      <%= text_area_tag :duplicate_export_text,
                        @duplicate_codes_text,
                        rows: 10,
                        readonly: true,
                        data: { clipboard_target: "source" },
                        class: "mt-5 block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
    </div>
  </div>
</section>