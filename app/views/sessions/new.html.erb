<% content_for :title, "Ingresar" %>

<div class="mx-auto max-w-md rounded-3xl border border-slate-200 bg-white p-8 shadow-sm shadow-slate-200/50">
  <div class="space-y-2">
    <h1 class="text-2xl font-semibold tracking-tight text-slate-950">Ingresar</h1>
    <p class="text-sm text-slate-600">Accede con tu correo y contraseña.</p>
  </div>

  <%= form_with url: session_path, class: "mt-8 space-y-4" do |form| %>
    <div class="space-y-2">
      <%= form.label :email, "Correo electrónico", class: "block text-sm font-medium text-slate-700" %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username", value: params[:email], class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 placeholder:text-slate-400 focus:border-accent-700 focus:ring-accent-700" %>
    </div>

    <div class="space-y-2">
      <%= form.label :password, "Contraseña", class: "block text-sm font-medium text-slate-700" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 placeholder:text-slate-400 focus:border-accent-700 focus:ring-accent-700" %>
    </div>

    <%= form.submit "Ingresar", class: "inline-flex w-full items-center justify-center rounded-2xl bg-accent-700 px-4 py-3 font-medium text-white transition hover:bg-accent-900" %>
  <% end %>

  <div class="mt-6 flex flex-col gap-3 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between">
    <%= link_to "Recuperar acceso", new_password_path, class: "font-medium text-accent-700 hover:text-accent-900" %>
    <%= link_to "Crear cuenta con invitación", new_registration_path, class: "font-medium text-slate-700 hover:text-slate-950" %>
  </div>
</div>
