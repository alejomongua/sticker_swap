<% content_for :title, "Mercado" %>

<div class="space-y-6">
  <div class="space-y-2">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-950">Mercado</h1>
    <p class="text-sm text-slate-600">Aquí ves quién tiene figuras que te faltan y quién necesita tus repetidas.</p>
  </div>

  <% if @match_summaries.any? %>
    <div class="space-y-5">
      <% @match_summaries.each do |summary| %>
        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-200/50">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 class="text-xl font-semibold text-slate-950"><%= summary.user.username %></h2>
              <p class="mt-1 text-sm text-slate-600">
                <% if summary.direct_match? %>
                  Hay cruce directo para proponer un intercambio.
                <% else %>
                  Hay coincidencia parcial, pero todavía no hay canje directo.
                <% end %>
              </p>
            </div>

            <% if summary.direct_match? %>
              <span class="inline-flex rounded-full bg-emerald-100 px-3 py-2 text-sm font-medium text-emerald-900">Cruce directo</span>
            <% end %>
          </div>

          <div class="mt-6 grid gap-6 lg:grid-cols-2">
            <% unless summary.direct_match? %>
              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Te puede dar</h3>
                <% if summary.can_request.any? %>
                  <ul class="mt-3 flex flex-wrap gap-2">
                    <% summary.can_request.each do |sticker| %>
                      <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"><%= sticker.display_name %></li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="mt-3 text-sm text-slate-600">No tiene figuras que hoy te falten.</p>
                <% end %>
              </div>

              <div>
                <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Le puedes ofrecer</h3>
                <% if summary.can_offer.any? %>
                  <ul class="mt-3 flex flex-wrap gap-2">
                    <% summary.can_offer.each do |sticker| %>
                      <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-800"><%= sticker.display_name %></li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="mt-3 text-sm text-slate-600">No necesita tus repetidas actuales.</p>
                <% end %>
              </div>
            <% end %>
          </div>

          <% if summary.direct_match? %>
            <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-5">
              <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Armar trato</h3>
              <p class="mt-1 text-sm text-slate-600">Haz clic en los badges para ir llenando qué quieres solicitar y qué vas a ofrecer.</p>

              <div class="mt-5">
                <%= render "swap_offers/trade_builder",
                           receiver_id: summary.user.id,
                           countered_from_id: nil,
                           requestable_stickers: summary.can_request,
                           offerable_stickers: summary.can_offer,
                           initial_requested_codes_text: "",
                           initial_offered_codes_text: "",
                           submit_label: "Proponer trato" %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm shadow-slate-200/50">
      <p class="text-sm text-slate-600">Todavía no encontramos coincidencias. Carga faltantes y repetidas en tu panel para empezar.</p>
    </div>
  <% end %>
</div>
