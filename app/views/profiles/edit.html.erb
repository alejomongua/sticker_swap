<% content_for :title, "Perfil" %>

<div class="space-y-6">
  <div class="space-y-2">
    <h1 class="text-3xl font-semibold tracking-tight text-slate-950">Perfil</h1>
    <p class="text-sm text-slate-600">Gestiona tu cuenta, tu correo y la preferencia de notificaciones.</p>
  </div>

  <div class="max-w-3xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm shadow-slate-200/50">
    <%= render "shared/form_errors", record: @user %>

    <%= form_with model: @user, url: profile_path, class: "mt-6 space-y-6" do |form| %>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="space-y-2">
          <%= form.label :username, class: "block text-sm font-medium text-slate-700" %>
          <%= form.text_field :username, required: true, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
        </div>

        <div class="space-y-2">
          <%= form.label :email, class: "block text-sm font-medium text-slate-700" %>
          <%= form.email_field :email, required: true, autocomplete: "username", class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
        </div>
      </div>

      <label class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
        <%= form.check_box :receive_offer_notifications, class: "mt-1 rounded border-slate-300 text-accent-700 focus:ring-accent-700" %>
        <span>Recibir correos cuando llegue una propuesta nueva.</span>
      </label>

      <div class="space-y-4 rounded-3xl border border-slate-200 p-5">
        <div>
          <h2 class="text-lg font-semibold text-slate-950">Cambiar contraseña</h2>
          <p class="mt-1 text-sm text-slate-600">Completa estos campos sólo si quieres reemplazar tu contraseña actual.</p>
        </div>

        <div class="space-y-2">
          <%= label_tag :user_current_password, "Contraseña actual", class: "block text-sm font-medium text-slate-700" %>
          <%= password_field_tag "user[current_password]", nil, autocomplete: "current-password", class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="space-y-2">
            <%= form.label :password, "Nueva contraseña", class: "block text-sm font-medium text-slate-700" %>
            <%= form.password_field :password, autocomplete: "new-password", maxlength: 72, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
          </div>

          <div class="space-y-2">
            <%= form.label :password_confirmation, "Confirmación", class: "block text-sm font-medium text-slate-700" %>
            <%= form.password_field :password_confirmation, autocomplete: "new-password", maxlength: 72, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 focus:border-accent-700 focus:ring-accent-700" %>
          </div>
        </div>
      </div>

      <%= form.submit "Guardar cambios", class: "inline-flex items-center justify-center rounded-2xl bg-accent-700 px-5 py-3 font-medium text-white transition hover:bg-accent-900" %>
    <% end %>
  </div>
</div>
