<% content_for :title, "Recuperar acceso" %>

<div class="mx-auto max-w-md rounded-3xl border border-slate-200 bg-white p-8 shadow-sm shadow-slate-200/50">
  <div class="space-y-2">
    <h1 class="text-2xl font-semibold tracking-tight text-slate-950">Recuperar acceso</h1>
    <p class="text-sm text-slate-600">Te enviaremos un enlace para actualizar tu contraseña.</p>
  </div>

  <%= form_with url: passwords_path, class: "mt-8 space-y-4" do |form| %>
    <div class="space-y-2">
      <%= form.label :email, "Correo electrónico", class: "block text-sm font-medium text-slate-700" %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username", value: params[:email], class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 placeholder:text-slate-400 focus:border-accent-700 focus:ring-accent-700" %>
    </div>

    <%= form.submit "Enviar enlace", class: "inline-flex w-full items-center justify-center rounded-2xl bg-accent-700 px-4 py-3 font-medium text-white transition hover:bg-accent-900" %>
  <% end %>
</div>
