<% content_for :title, "Actualizar contraseña" %>

<div class="mx-auto max-w-md rounded-3xl border border-slate-200 bg-white p-8 shadow-sm shadow-slate-200/50">
  <div class="space-y-2">
    <h1 class="text-2xl font-semibold tracking-tight text-slate-950">Actualizar contraseña</h1>
    <p class="text-sm text-slate-600">Elige una nueva contraseña para tu cuenta.</p>
  </div>

  <%= form_with url: password_path(params[:token]), method: :put, class: "mt-8 space-y-4" do |form| %>
    <div class="space-y-2">
      <%= form.label :password, "Nueva contraseña", class: "block text-sm font-medium text-slate-700" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 placeholder:text-slate-400 focus:border-accent-700 focus:ring-accent-700" %>
    </div>

    <div class="space-y-2">
      <%= form.label :password_confirmation, "Confirmación", class: "block text-sm font-medium text-slate-700" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "block w-full rounded-2xl border-slate-200 bg-slate-50 px-4 py-3 text-slate-950 placeholder:text-slate-400 focus:border-accent-700 focus:ring-accent-700" %>
    </div>

    <%= form.submit "Guardar contraseña", class: "inline-flex w-full items-center justify-center rounded-2xl bg-accent-700 px-4 py-3 font-medium text-white transition hover:bg-accent-900" %>
  <% end %>
</div>
